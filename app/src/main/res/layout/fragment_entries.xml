<?xml version="1.0" encoding="utf-8"?>
<!-- Файл: fragment_entries.xml -->
<!-- Связан с: EntriesFragment.java -->
<!-- Назначение: макет фрагмента со списком записей, поиском и кнопкой фильтра -->

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Строка поиска и кнопка фильтра -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/search"
            app:boxBackgroundMode="outline"
            
            
            app:boxStrokeColor="@color/bee_primary"
            app:endIconMode="clear_text">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFilter"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton.Icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/filter"
            android:textColor="@color/bee_text_primary"
            app:icon="@android:drawable/ic_menu_sort_by_size"
            app:iconTint="@color/bee_primary_dark"
            app:strokeColor="@color/bee_primary" />
    </LinearLayout>

    <!-- Панель фильтров (изначально скрыта) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/filterPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        app:cardBackgroundColor="#FFF9E6"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Фильтры:"
                android:textColor="@color/bee_text_primary"
                android:textStyle="bold" />

            <!-- Фильтр по пользователю -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Пользователь:"
                android:textColor="@color/bee_text_secondary" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupUsers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:chipSpacing="8dp"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAllUsers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Все"
                    app:chipBackgroundColor="@color/bee_primary"
                    app:chipStrokeColor="@color/bee_primary_dark"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Мама"
                    app:chipBackgroundColor="@color/bee_amber_light"
                    app:chipStrokeColor="@color/bee_primary_dark"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipDad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Папа"
                    app:chipBackgroundColor="@color/bee_accent"
                    app:chipStrokeColor="@color/bee_primary_dark"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipChild"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ребенок"
                    app:chipBackgroundColor="@color/bee_green"
                    app:chipStrokeColor="@color/bee_olive"
                    app:chipStrokeWidth="1dp" />
            </com.google.android.material.chip.ChipGroup>

            <!-- Фильтр по дням недели (только для занятий) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Дни недели:"
                android:textColor="@color/bee_text_secondary" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupDays"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:chipSpacing="8dp"
                app:singleLine="true"
                app:singleSelection="false">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Пн"
                    app:chipBackgroundColor="@color/bee_amber_light"
                    app:chipStrokeColor="@color/bee_primary_dark"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Вт"
                    app:chipBackgroundColor="@color/bee_amber_light"
                    app:chipStrokeColor="@color/bee_primary_dark"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipWed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ср"
                    app:chipBackgroundColor="@color/bee_amber_light"
                    app:chipStrokeColor="@color/bee_primary_dark"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipThu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Чт"
                    app:chipBackgroundColor="@color/bee_amber_light"
                    app:chipStrokeColor="@color/bee_primary_dark"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipFri"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Пт"
                    app:chipBackgroundColor="@color/bee_amber_light"
                    app:chipStrokeColor="@color/bee_primary_dark"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Сб"
                    app:chipBackgroundColor="@color/bee_green"
                    app:chipStrokeColor="@color/bee_olive"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSun"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Вс"
                    app:chipBackgroundColor="@color/bee_green"
                    app:chipStrokeColor="@color/bee_olive"
                    app:chipStrokeWidth="1dp" />
            </com.google.android.material.chip.ChipGroup>

            <!-- Кнопка сброса фильтров -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResetFilters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Сбросить фильтры"
                android:textColor="@color/white"
                app:backgroundTint="@color/bee_brown"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- RecyclerView для списка записей -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerEntries"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        tools:listitem="@layout/item_entry" />

    <!-- Сообщение, если список пуст -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="Нет записей"
        android:textColor="@color/bee_text_secondary"
        android:textSize="18sp"
        android:visibility="gone" />

</LinearLayout>