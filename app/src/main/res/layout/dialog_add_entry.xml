<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Тип записи:"
            android:textColor="@color/bee_text_primary"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinnerType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />

        <EditText
            android:id="@+id/editTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Название"
            android:padding="8dp"
            android:background="@android:drawable/editbox_background" />

        <!-- Поля для пароля -->
        <LinearLayout
            android:id="@+id/layoutPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/editLoginPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Логин"
                android:padding="8dp"
                android:background="@android:drawable/editbox_background" />

            <EditText
                android:id="@+id/editPasswordField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Пароль"
                android:inputType="textPassword"
                android:padding="8dp"
                android:background="@android:drawable/editbox_background" />

            <EditText
                android:id="@+id/editCommentPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Комментарий"
                android:padding="8dp"
                android:background="@android:drawable/editbox_background" />
        </LinearLayout>

        <!-- Поля для занятия -->
        <LinearLayout
            android:id="@+id/layoutLesson"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/editUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Ссылка"
                android:padding="8dp"
                android:background="@android:drawable/editbox_background" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Дни недели:"
                android:textColor="@color/bee_text_primary" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupDays"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:chipSpacing="8dp"
                app:singleLine="true"
                app:singleSelection="false">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Пн"
                    app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Вт"
                    app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipWed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ср"
                    app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipThu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Чт"
                    app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipFri"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Пт"
                    app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Сб"
                    app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSun"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Вс"
                    app:checkedIconVisible="false" />
            </com.google.android.material.chip.ChipGroup>

            <EditText
                android:id="@+id/editStartTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Время начала (например, 18:00)"
                android:padding="8dp"
                android:background="@android:drawable/editbox_background" />

            <EditText
                android:id="@+id/editLoginLesson"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Логин"
                android:padding="8dp"
                android:background="@android:drawable/editbox_background" />

            <EditText
                android:id="@+id/editPasswordLesson"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Пароль"
                android:inputType="textPassword"
                android:padding="8dp"
                android:background="@android:drawable/editbox_background" />

            <EditText
                android:id="@+id/editCommentLesson"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Комментарий"
                android:padding="8dp"
                android:background="@android:drawable/editbox_background" />
        </LinearLayout>

        <!-- Видимость пароля -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Кто может видеть пароль:"
            android:textColor="@color/bee_text_primary"
            android:textStyle="bold" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupVisibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:chipSpacing="8dp"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipVisibilityAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="Все"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipVisibilityParents"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Только родители"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipVisibilityMe"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Только я"
                app:checkedIconVisible="false" />
        </com.google.android.material.chip.ChipGroup>

        <!-- Кнопки -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Сохранить"
                android:backgroundTint="@color/bee_primary" />

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Отмена"
                android:backgroundTint="@color/bee_brown" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>