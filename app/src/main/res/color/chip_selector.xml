<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Нажатое состояние -->
    <item android:state_pressed="true">
        <color android:color="#80E99228" /> <!-- Полупрозрачный темный -->
    </item>
    <!-- Выбранное состояние -->
    <item android:state_checked="true">
        <color android:color="#E99228" /> <!-- Темно-желтый -->
    </item>
    <!-- Обычное состояние -->
    <item>
        <color android:color="#FFEC53" /> <!-- Светло-желтый -->
    </item>
</selector>